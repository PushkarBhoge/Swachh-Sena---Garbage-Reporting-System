<%- include('../partials/header') %>

<!-- ═══ HERO SECTION ═══ -->
<div class="hero-section text-white" style="padding:5rem 0 6rem; min-height:560px; display:flex; align-items:center;">
    <div class="container px-3" style="position:relative; z-index:1;">
        <div class="row align-items-center g-4">
            <!-- Left: Text -->
            <div class="col-lg-7 col-md-8 text-center text-md-start">
                <!-- Pill badge -->
                <div class="mb-3"
                    style="display:inline-flex; align-items:center; gap:8px; background:rgba(255,255,255,0.13); border:1px solid rgba(255,255,255,0.28); border-radius:50px; padding:6px 18px; font-size:0.82rem; font-weight:600; letter-spacing:0.5px; backdrop-filter:blur(10px);">
                    <span>🌱</span>
                    <%= t('Join the Green Revolution') %>
                </div>
                <h1 class="display-4 fw-black mt-2" style="font-weight:900; letter-spacing:-1px; line-height:1.1;">
                    <%= t('Keep Your City Clean') %>
                </h1>
                <p class="lead mt-3 mb-4" style="opacity:0.9; max-width:540px; margin:0 auto 1.5rem; font-size:1.05rem;">
                    <%= t('Report garbage issues and help make your community cleaner') %>
                </p>
                <div class="d-flex flex-column flex-sm-row justify-content-center justify-content-md-start gap-3 mt-4">
                    <a href="/report" class="btn btn-light btn-lg px-4" <% if (!userId) { %>onclick="openAuthModal('login'); return false;"<% } %>>
                        <i class="fas fa-camera me-2"></i>
                        <%= t('Report Garbage Now') %>
                    </a>
                    <a href="/reports" class="btn btn-outline-light btn-lg px-4">
                        <i class="fas fa-map-marked-alt me-2"></i>
                        <%= t('View Reports') %>
                    </a>
                </div>
            </div>
            <!-- Right: Logo -->
            <div class="col-lg-5 col-md-4 text-center d-none d-md-flex justify-content-center align-items-center">
                <img src="<%= language === 'mr' ? '/assets/logo-mr.png' : '/assets/logo-eng.png' %>"
                    alt="Swachh Sena" class="hero-logo-xl">
            </div>
        </div>
    </div>
</div>

<!-- ═══ HOW IT WORKS ═══ -->
<div class="container my-5">
    <div class="text-center mb-4">
        <h2 style="font-weight:800; font-size:1.9rem; color:var(--text-primary);">
            <%= t('How It Works') %>
        </h2>
        <p style="color:var(--text-secondary); max-width:480px; margin:0.5rem auto 0; font-size:0.95rem;">
            <%= t('Simple 3-step process to report and track garbage cleanup') %>
        </p>
    </div>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 text-center" style="border-top:4px solid #28a745 !important;">
                <div class="card-body py-4">
                    <div style="width:64px; height:64px; background:linear-gradient(135deg,#28a745,#20c997); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 1rem; box-shadow:0 8px 24px rgba(40,167,69,0.3);">
                        <i class="fas fa-camera text-white" style="font-size:1.4rem;"></i>
                    </div>
                    <div style="width:28px; height:28px; background:#28a745; border-radius:50%; font-weight:800; font-size:0.8rem; color:white; display:flex; align-items:center; justify-content:center; margin:-8px auto 12px; position:relative; z-index:1;">1</div>
                    <h5 style="font-weight:700; color:var(--text-primary);">📸 <%= t('Report') %></h5>
                    <p style="color:var(--text-secondary); font-size:0.9rem; line-height:1.6; margin-bottom:0;">
                        <%= t('Take a photo and report garbage in your area with location details') %>
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 text-center" style="border-top:4px solid #17a2b8 !important;">
                <div class="card-body py-4">
                    <div style="width:64px; height:64px; background:linear-gradient(135deg,#17a2b8,#20c997); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 1rem; box-shadow:0 8px 24px rgba(23,162,184,0.3);">
                        <i class="fas fa-users text-white" style="font-size:1.4rem;"></i>
                    </div>
                    <div style="width:28px; height:28px; background:#17a2b8; border-radius:50%; font-weight:800; font-size:0.8rem; color:white; display:flex; align-items:center; justify-content:center; margin:-8px auto 12px; position:relative; z-index:1;">2</div>
                    <h5 style="font-weight:700; color:var(--text-primary);">👥 <%= t('Assign') %></h5>
                    <p style="color:var(--text-secondary); font-size:0.9rem; line-height:1.6; margin-bottom:0;">
                        <%= t('Admin assigns cleaning teams to reported locations') %>
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 text-center" style="border-top:4px solid #20c997 !important;">
                <div class="card-body py-4">
                    <div style="width:64px; height:64px; background:linear-gradient(135deg,#20c997,#28a745); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 1rem; box-shadow:0 8px 24px rgba(32,201,151,0.3);">
                        <i class="fas fa-check-circle text-white" style="font-size:1.4rem;"></i>
                    </div>
                    <div style="width:28px; height:28px; background:#20c997; border-radius:50%; font-weight:800; font-size:0.8rem; color:white; display:flex; align-items:center; justify-content:center; margin:-8px auto 12px; position:relative; z-index:1;">3</div>
                    <h5 style="font-weight:700; color:var(--text-primary);">✅ <%= t('Clean') %></h5>
                    <p style="color:var(--text-secondary); font-size:0.9rem; line-height:1.6; margin-bottom:0;">
                        <%= t('Teams clean the area and upload after photos') %>
                    </p>
                </div>
            </div>
        </div>
    </div>
    <div class="text-center mt-4">
        <div class="d-flex flex-column flex-md-row justify-content-center gap-3">
            <a href="/report" class="btn btn-success btn-lg px-4" <% if (!userId) { %>onclick="openAuthModal('login'); return false;"<% } %>>
                <i class="fas fa-flag me-2"></i>
                <%= t('Report Garbage') %>
            </a>
            <a href="/reports" class="btn btn-outline-success btn-lg px-4">
                <i class="fas fa-list me-2"></i>
                <%= t('View Reports') %>
            </a>
        </div>
    </div>
</div>

<%- include('../partials/testimonials') %>

<!-- ═══ FAQ SECTION ═══ -->
<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <h2 class="text-center mb-2" style="font-weight:800; font-size:1.8rem; color:var(--text-primary);">
                <%= t('Frequently Asked Questions') %>
            </h2>
            <p class="text-center mb-4" style="color:var(--text-secondary); font-size:0.95rem;">
                <%= t('Everything you need to know about Swachh Sena') %>
            </p>
            <div class="accordion" id="faqAccordion" style="display:flex; flex-direction:column; gap:10px;">
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                            <%= t('How do I report garbage in my area?') %>
                            <i class="fas fa-plus ms-auto"></i>
                        </button>
                    </h2>
                    <div id="faq1" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            <%= t('Click on "Report Garbage" button, take a photo of the garbage spot, fill in the location details including area, landmark, city, and pincode, add a description, and submit the report. Our team will review and assign it to a cleanup crew.') %>
                        </div>
                    </div>
                </div>
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                            <%= t('How long does it take for the cleanup team to respond?') %>
                            <i class="fas fa-plus ms-auto"></i>
                        </button>
                    </h2>
                    <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            <%= t('Our cleanup teams typically respond within 24-48 hours of report submission. Response time may vary based on the location and severity of the issue. You can track the status of your report on the "View Reports" page.') %>
                        </div>
                    </div>
                </div>
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                            <%= t('Can I track the status of my garbage report?') %>
                            <i class="fas fa-plus ms-auto"></i>
                        </button>
                    </h2>
                    <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            <%= t('Yes! Visit the "View Reports" page to see all submitted reports. Each report shows its current status: Pending (awaiting assignment), Assigned (team assigned), or Cleaned (completed with after photos). You can see before and after photos once cleanup is complete.') %>
                        </div>
                    </div>
                </div>
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                            <%= t('Is there a cost to report garbage or use this service?') %>
                            <i class="fas fa-plus ms-auto"></i>
                        </button>
                    </h2>
                    <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            <%= t('No, our garbage reporting service is completely free for all citizens. We are a community-driven initiative focused on keeping our city clean. However, donations are welcome to help us expand our operations and serve more areas.') %>
                        </div>
                    </div>
                </div>
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq5">
                            <%= t('How can I volunteer or support this initiative?') %>
                            <i class="fas fa-plus ms-auto"></i>
                        </button>
                    </h2>
                    <div id="faq5" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            <%= t('We welcome volunteers! You can support us by making a donation through our "Donate" page, spreading awareness about the platform, participating in community cleanup drives, or joining our newsletter to stay informed about volunteer opportunities and events.') %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ═══ NEWSLETTER SECTION ═══ -->
<% if (!subscriberEmail) { %>
<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="card" style="background:linear-gradient(135deg,#1a5e2a 0%,#28a745 50%,#20c997 100%) !important; border:none !important; border-radius:24px !important; overflow:hidden; position:relative;">
                <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 80% 20%, rgba(255,255,255,0.12) 0%, transparent 60%); pointer-events:none;"></div>
                <div class="card-body text-center py-5 px-4" style="position:relative; z-index:1;">
                    <div style="display:inline-flex; align-items:center; justify-content:center; width:62px; height:62px; background:rgba(255,255,255,0.18); border-radius:50%; margin-bottom:1rem; border:2px solid rgba(255,255,255,0.3);">
                        <i class="fas fa-envelope text-white" style="font-size:1.5rem;"></i>
                    </div>
                    <h3 class="text-white mb-2" style="font-weight:800; font-size:1.6rem;">
                        <%= t('Join Our Community') %>
                    </h3>
                    <p class="text-white mb-4" style="opacity:0.88; font-size:0.95rem; max-width:420px; margin:0 auto 1.5rem;">
                        <%= t('Stay updated with our latest cleanup drives, environmental tips, and community initiatives') %>
                    </p>
                    <form id="newsletterForm" class="row g-2 justify-content-center">
                        <div class="col-md-6">
                            <input type="email" class="form-control form-control-lg" id="emailInput"
                                placeholder="<%= t('Enter your email') %>" required
                                style="border-radius:50px; border:2px solid rgba(255,255,255,0.3); background:rgba(255,255,255,0.9); font-weight:500; padding:12px 22px;">
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn btn-light w-100 btn-lg"
                                style="border-radius:50px; font-weight:700; color:#198754; min-height:52px;">
                                <i class="fas fa-paper-plane me-1"></i>
                                <%= t('Subscribe') %>
                            </button>
                        </div>
                    </form>
                    <p class="text-white mt-3 mb-0" style="opacity:0.6; font-size:0.8rem;">
                        🔒 <%= t('We respect your privacy. Unsubscribe anytime.') %>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
<% } %>

<!-- Toast Notification -->
<div id="toast" class="toast-notification">
    <i class="fas fa-check-circle"></i>
    <span id="toastMessage"></span>
</div>

<%- include('../partials/footer') %>

<script>
    function showToast(message, type = 'success') {
        const toast = document.getElementById('toast');
        const toastMessage = document.getElementById('toastMessage');
        const icon = toast.querySelector('i');
        toastMessage.textContent = message;
        if (type === 'success') {
            toast.className = 'toast-notification toast-success show';
            icon.className = 'fas fa-check-circle';
        } else {
            toast.className = 'toast-notification toast-error show';
            icon.className = 'fas fa-exclamation-circle';
        }
        setTimeout(() => { toast.classList.remove('show'); }, 4000);
    }

    const newsletterForm = document.getElementById('newsletterForm');
    if (newsletterForm) {
        newsletterForm.addEventListener('submit', async function (e) {
            e.preventDefault();
            const email = document.getElementById('emailInput').value;
            try {
                const response = await fetch('/subscribe', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                });
                const data = await response.json();
                if (response.ok) {
                    showToast('✓ Subscribed successfully!', 'success');
                    localStorage.setItem('subscriberEmail', email);
                    this.reset();
                    setTimeout(() => location.reload(), 2000);
                } else {
                    showToast(data.error || 'Subscription failed', 'error');
                }
            } catch (error) {
                showToast('Error occurred', 'error');
            }
        });
    }

    document.querySelectorAll('.accordion-button').forEach(button => {
        button.addEventListener('click', function () {
            const icon = this.querySelector('i');
            if (this.classList.contains('collapsed')) {
                icon.classList.remove('fa-minus');
                icon.classList.add('fa-plus');
            } else {
                icon.classList.remove('fa-plus');
                icon.classList.add('fa-minus');
            }
        });
    });
</script>
