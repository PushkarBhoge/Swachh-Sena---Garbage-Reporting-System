<%- include('../partials/header') %>

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><%= t('Garbage Reports') %></h2>
        <div class="btn-group" role="group">
            <a href="/reports?filter=all" class="btn <%= filter === 'all' ? 'btn-success' : 'btn-outline-success' %>">
                <i class="fas fa-globe"></i> <%= t('All Reports') %>
            </a>
            <a href="/reports?filter=mine" class="btn <%= filter === 'mine' ? 'btn-success' : 'btn-outline-success' %>">
                <i class="fas fa-user"></i> <%= t('My Reports') %>
            </a>
        </div>
    </div>
    
    <% if (success) { %>
        <div class="alert alert-success" data-auto-hide="true">✓ Report submitted!</div>
    <% } %>
    
    <% if (reports.length === 0) { %>
        <div class="alert alert-info"><%= t('No reports yet') %></div>
    <% } else { %>
        <div class="row">
            <% reports.forEach(report => { 
                const formatDate = (date) => {
                    return new Date(date).toLocaleDateString(language === 'mr' ? 'mr-IN' : 'en-US', { year: 'numeric', month: 'numeric', day: 'numeric' });
                };
                const formatNumber = (num) => {
                    if (language === 'mr') {
                        const devanagariMap = {'0':'०','1':'१','2':'२','3':'३','4':'४','5':'५','6':'६','7':'७','8':'८','9':'९'};
                        return num.toString().replace(/[0-9]/g, d => devanagariMap[d]);
                    }
                    return num;
                };
            %>
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card">
                        <img src="<%= report.beforeImage.url %>" class="card-img-top" alt="Before Image" style="height: 200px; object-fit: cover;">
                        <div class="card-body">
                            <h5 class="card-title">
                                <span class="badge bg-<%= report.status === 'Pending' ? 'warning' : report.status === 'Assigned' ? 'info' : 'success' %>">
                                    <%= t(report.status) %>
                                </span>
                            </h5>
                            <p class="card-text">
                                <strong><%= t('Location:') %></strong> <%= report.location.area %>, <%= report.location.landmark %><br>
                                <strong><%= t('City:') %></strong> <%= report.location.city %> - <%= formatNumber(report.location.pincode) %><br>
                                <strong><%= t('Description:') %></strong> <%= report.description %>
                            </p>
                            <small class="text-muted"><%= t('Reported on:') %> <%= formatDate(report.createdAt) %></small>
                            
                            <% if (report.status === 'Cleaned' && report.afterImage) { %>
                                <hr>
                                <h6><%= t('After Cleaning:') %> 
                                    <button type="button" class="btn btn-success btn-sm ms-2" onclick="viewImage('<%= report.afterImage.url %>')">
                                        <i class="fas fa-eye"></i> <%= t('View') %>
                                    </button>
                                </h6>
                                <% if (report.cleanedAt) { %>
                                    <small class="text-muted"><%= t('Cleaned on:') %> <%= formatDate(report.cleanedAt) %></small>
                                <% } %>
                            <% } %>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>

<!-- Image View Modal -->
<div class="modal fade" id="imageViewModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><%= t('View Image') %></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <img id="modalImage" src="" class="img-fluid" alt="Image">
            </div>
        </div>
    </div>
</div>

<script>
function viewImage(imageUrl) {
    document.getElementById('modalImage').src = imageUrl;
    new bootstrap.Modal(document.getElementById('imageViewModal')).show();
}
</script>

<%- include('../partials/footer') %>