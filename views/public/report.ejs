<%- include('../partials/header') %>
<script>
<% if (!userId) { %>
document.addEventListener('DOMContentLoaded', function() {
    document.querySelector('form[action="/report"]').addEventListener('submit', function(e) {
        e.preventDefault();
        openAuthModal('login');
    });
});
<% } %>
</script>

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <!-- Page Header -->
            <div class="text-center mb-4">
                <div style="display:inline-flex; align-items:center; justify-content:center; width:64px; height:64px; background:linear-gradient(135deg,#28a745,#20c997); border-radius:50%; margin-bottom:1rem; box-shadow:0 8px 24px rgba(40,167,69,0.3);">
                    <i class="fas fa-flag text-white" style="font-size:1.5rem;"></i>
                </div>
                <h2 style="font-weight:800; color:var(--text-primary);">
                    <%= t('Report Garbage') %>
                </h2>
                <p style="color:var(--text-secondary); font-size:0.9rem;">
                    <%= t('Help us keep your city clean by reporting a garbage spot near you.') %>
                </p>
            </div>

            <div class="card" style="border-radius:24px !important; box-shadow:0 12px 40px rgba(40,167,69,0.12);">
                <!-- Card Header -->
                <div class="card-header" style="background:linear-gradient(135deg,#28a745,#20c997) !important; border:none !important; border-radius:24px 24px 0 0 !important; padding:1.1rem 1.5rem;">
                    <div class="d-flex align-items-center gap-2">
                        <i class="fas fa-camera-retro text-white"></i>
                        <h5 class="mb-0 text-white" style="font-weight:700;"><%= t('Report Garbage') %></h5>
                    </div>
                </div>

                <div class="card-body p-4">
                    <form action="/report" method="POST" enctype="multipart/form-data">

                        <!-- Upload Zone -->
                        <div class="mb-4">
                            <label class="form-label">
                                <i class="fas fa-image me-1" style="color:#28a745;"></i>
                                <%= t('Upload Garbage Images') %> <span style="color:red;">*</span>
                            </label>
                            <div id="uploadZone" style="border:2px dashed #28a745; border-radius:16px; padding:2rem; text-align:center; cursor:pointer; background:rgba(40,167,69,0.04); transition:all 0.3s ease;" onclick="document.getElementById('beforeImages').click()">
                                <div id="uploadPlaceholder">
                                    <div style="width:54px; height:54px; background:rgba(40,167,69,0.1); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 0.75rem;">
                                        <i class="fas fa-cloud-upload-alt" style="font-size:1.5rem; color:#28a745;"></i>
                                    </div>
                                    <p style="font-weight:600; color:var(--text-secondary); margin:0 0 4px;">
                                        <%= t('Click to upload or drag & drop') %>
                                    </p>
                                    <p style="color:var(--text-muted); font-size:0.8rem; margin:0;"><%= t('PNG, JPG up to 10MB · Multiple allowed') %></p>
                                </div>
                                <input type="file" id="beforeImages" name="beforeImages"
                                       accept="image/*" multiple required onchange="showFileBadges(this)"
                                       style="display:none;">
                            </div>
                            <div id="fileBadgesWrap" style="display:none; margin-top:8px; display:flex; flex-wrap:wrap; gap:6px;"></div>
                        </div>

                        <!-- Location Row -->
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label for="area" class="form-label">
                                    <i class="fas fa-road me-1" style="color:#28a745;"></i>
                                    <%= t('Area/Street') %> <span style="color:red;">*</span>
                                </label>
                                <input type="text" class="form-control" id="area" name="area"
                                       placeholder="<%= t('e.g. MG Road') %>" required>
                            </div>
                            <div class="col-md-6">
                                <label for="landmark" class="form-label">
                                    <i class="fas fa-map-marker me-1" style="color:#28a745;"></i>
                                    <%= t('Landmark') %> <span style="color:red;">*</span>
                                </label>
                                <input type="text" class="form-control" id="landmark" name="landmark"
                                       placeholder="<%= t('e.g. Near Bus Stop') %>" required>
                            </div>
                        </div>
                        
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label for="city" class="form-label">
                                    <i class="fas fa-city me-1" style="color:#28a745;"></i>
                                    <%= t('City') %> <span style="color:red;">*</span>
                                </label>
                                <input type="text" class="form-control" id="city" name="city"
                                       placeholder="<%= t('e.g. Pune') %>" required>
                            </div>
                            <div class="col-md-6">
                                <label for="pincode" class="form-label">
                                    <i class="fas fa-hashtag me-1" style="color:#28a745;"></i>
                                    <%= t('Pincode') %> <span style="color:red;">*</span>
                                </label>
                                <input type="text" class="form-control" id="pincode" name="pincode"
                                       pattern="[0-9]{6}" placeholder="<%= t('6-digit pincode') %>" required>
                            </div>
                        </div>
                        
                        <!-- Description -->
                        <div class="mb-4">
                            <label for="description" class="form-label">
                                <i class="fas fa-align-left me-1" style="color:#28a745;"></i>
                                <%= t('Description') %> <span style="color:red;">*</span>
                            </label>
                            <div class="position-relative">
                                <textarea class="form-control" id="description" name="description"
                                          rows="4" placeholder="<%= t('Describe the garbage issue...') %>" required
                                          style="resize:none; padding-bottom:2rem;"></textarea>
                                <small class="position-absolute" id="charCount"
                                       style="bottom:10px; right:14px; color:var(--text-muted); font-size:0.8rem; font-weight:500;">
                                    0 / <%= language === 'mr' ? '५००' : '500' %>
                                </small>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-flex gap-3 flex-wrap">
                            <button type="submit" class="btn btn-success btn-lg px-4">
                                <i class="fas fa-paper-plane me-2"></i><%= t('Submit Report') %>
                            </button>
                            <button type="button" class="btn btn-outline-secondary btn-lg px-4" id="clearBtn">
                                <i class="fas fa-eraser me-2"></i><%= t('Clear') %>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
const descTextarea = document.getElementById('description');
const charCount    = document.getElementById('charCount');
const maxChars  = 500;
const isMr      = '<%= language %>' === 'mr';
const devanagari = n => isMr ? n.toString().replace(/[0-9]/g, d => '०१२३४५६७८९'[d]) : n.toString();

document.getElementById('clearBtn').addEventListener('click', function() {
    document.getElementById('beforeImages').value = '';
    ['area','landmark','city','pincode','description'].forEach(id => document.getElementById(id).value = '');
    charCount.textContent = devanagari(0) + ' / ' + devanagari(maxChars);
    charCount.style.color = 'var(--text-muted)';
    const wrap = document.getElementById('fileBadgesWrap');
    wrap.innerHTML = ''; wrap.style.display = 'none';
    _rDataURLs = []; _rFileList = new DataTransfer();
    const zone = document.getElementById('uploadZone');
    zone.style.borderColor = '#28a745'; zone.style.background = 'rgba(40,167,69,0.04)';
});

if (descTextarea) {
    descTextarea.addEventListener('input', function() {
        const count = this.value.length;
        charCount.textContent = devanagari(count) + ' / ' + devanagari(maxChars);
        charCount.style.color = count > 450 ? '#dc3545' : 'var(--text-muted)';
        if (count > maxChars) { this.value = this.value.substring(0, maxChars); charCount.textContent = devanagari(maxChars) + ' / ' + devanagari(maxChars); }
    });
}

let _rDataURLs = [];
let _rFileList = new DataTransfer();

function removeFile(i) {
    _rDataURLs.splice(i, 1);
    const newDT = new DataTransfer();
    Array.from(_rFileList.files).forEach((f, j) => { if (j !== i) newDT.items.add(f); });
    _rFileList = newDT;
    document.getElementById('beforeImages').files = _rFileList.files;
    rebuildChips_r();
}

function rebuildChips_r() {
    const wrap = document.getElementById('fileBadgesWrap');
    const zone = document.getElementById('uploadZone');
    wrap.innerHTML = '';
    if (!_rFileList.files.length) {
        wrap.style.display = 'none';
        zone.style.borderColor = '#28a745'; zone.style.background = 'rgba(40,167,69,0.04)';
        return;
    }
    wrap.style.display = 'flex';
    Array.from(_rFileList.files).forEach((file, i) => {
        const chip = document.createElement('span');
        chip.style.cssText = 'display:inline-flex;align-items:center;gap:6px;background:rgba(40,167,69,0.1);color:#198754;border-radius:50px;padding:4px 10px;font-size:0.8rem;font-weight:600;border:1px solid rgba(40,167,69,0.2);';
        const nameSpan = document.createElement('span');
        nameSpan.style.cursor = 'pointer';
        nameSpan.innerHTML = '<i class="fas fa-image me-1"></i>' + file.name;
        nameSpan.onclick = (e) => { e.stopPropagation(); openSlideshow(_rDataURLs, i); };
        const removeBtn = document.createElement('span');
        removeBtn.innerHTML = '&times;';
        removeBtn.title = 'Remove';
        removeBtn.style.cssText = 'display:none;cursor:pointer;font-size:1rem;line-height:1;color:#dc3545;font-weight:700;padding:0 2px;';
        removeBtn.onclick = (e) => { e.stopPropagation(); removeFile(i); };
        chip.appendChild(nameSpan);
        chip.appendChild(removeBtn);
        chip.addEventListener('mouseenter', () => removeBtn.style.display = 'inline');
        chip.addEventListener('mouseleave', () => removeBtn.style.display = 'none');
        wrap.appendChild(chip);
    });
}

function showFileBadges(input) {
    const zone = document.getElementById('uploadZone');
    if (!input.files || !input.files.length) return;
    zone.style.borderColor = '#20c997'; zone.style.background = 'rgba(32,201,151,0.06)';
    Array.from(input.files).forEach(file => {
        _rFileList.items.add(file);
        const i = _rDataURLs.length;
        _rDataURLs.push(null);
        const reader = new FileReader();
        reader.onload = e => { _rDataURLs[i] = e.target.result; };
        reader.readAsDataURL(file);
    });
    input.files = _rFileList.files;
    rebuildChips_r();
}

function openSlideshow(urls, start) {
    let idx = start;
    const el = document.createElement('div');
    el.className = 'modal fade'; el.tabIndex = -1;
    el.innerHTML = `<div class="modal-dialog modal-lg modal-dialog-centered"><div class="modal-content">
        <div class="modal-header" style="background:linear-gradient(135deg,#28a745,#20c997);border:none">
            <h5 class="modal-title text-white fw-bold"><i class="fas fa-images me-2"></i>Images</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body text-center p-2" style="position:relative;min-height:300px">
            <img id="ssImg" src="" class="img-fluid rounded" style="max-height:65vh">
            <button onclick="ssNav(-1)" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);background:rgba(40,167,69,0.15);border:1px solid rgba(40,167,69,0.3);color:var(--text-primary);font-size:1.8rem;border-radius:50%;width:42px;height:42px;cursor:pointer">&#8249;</button>
            <button onclick="ssNav(1)"  style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:rgba(40,167,69,0.15);border:1px solid rgba(40,167,69,0.3);color:var(--text-primary);font-size:1.8rem;border-radius:50%;width:42px;height:42px;cursor:pointer">&#8250;</button>
            <div id="ssCtr" style="color:var(--text-muted);font-size:0.85rem;margin-top:6px"></div>
        </div></div></div>`;
    document.body.appendChild(el);
    const modal = new bootstrap.Modal(el);
    window._ssU = urls; window._ssI = idx;
    const render = () => { document.getElementById('ssImg').src = window._ssU[window._ssI]; document.getElementById('ssCtr').textContent = (window._ssI+1)+' / '+window._ssU.length; };
    window.ssNav = d => { window._ssI = (window._ssI+d+window._ssU.length)%window._ssU.length; render(); };
    render(); modal.show();
    el.addEventListener('hidden.bs.modal', () => el.remove());
}

const zone = document.getElementById('uploadZone');
zone.addEventListener('dragover',  e => { e.preventDefault(); zone.style.borderColor='#20c997'; zone.style.background='rgba(32,201,151,0.08)'; });
zone.addEventListener('dragleave', () => { zone.style.borderColor='#28a745'; zone.style.background='rgba(40,167,69,0.04)'; });
zone.addEventListener('drop', e => {
    e.preventDefault();
    const input = document.getElementById('beforeImages');
    input.files = e.dataTransfer.files;
    showFileBadges(input);
});
</script>

<%- include('../partials/footer') %>