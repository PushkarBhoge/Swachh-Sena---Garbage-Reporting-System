<%- include('../partials/header') %>

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><%= t('Blogs') %></h2>
        <div class="btn-group" role="group">
            <a href="/blogs?filter=all" class="btn <%= filter === 'all' ? 'btn-success' : 'btn-outline-success' %>">
                <i class="fas fa-globe"></i> <%= t('All Blogs') %>
            </a>
            <a href="/blogs?filter=mine" class="btn <%= filter === 'mine' ? 'btn-success' : 'btn-outline-success' %>">
                <i class="fas fa-user"></i> <%= t('My Blogs') %>
            </a>
        </div>
    </div>
    
    <% if (success) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert" data-auto-hide="true">
            <%= t('✓ Blog published!') %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <% if (blogs.length === 0) { %>
        <div class="alert alert-info text-center">
            <i class="fas fa-info-circle"></i> <%= t('No blogs yet') %>
        </div>
    <% } else { %>
        <div class="row">
            <% blogs.forEach((blog, index) => { 
                const contentLength = blog.title.length + blog.description.length;
                const hasImages = blog.images && blog.images.length > 0;
                
                let colSize, imgHeight;
                if (contentLength < 150) {
                    colSize = 'col-md-4';
                    imgHeight = hasImages ? '250px' : 'auto';
                } else if (contentLength < 300) {
                    colSize = 'col-md-6';
                    imgHeight = hasImages ? '320px' : 'auto';
                } else {
                    colSize = 'col-md-8';
                    imgHeight = hasImages ? '400px' : 'auto';
                }
            %>
                <div class="<%= colSize %> mb-4">
                    <div class="card h-100">
                        <% if (hasImages) { %>
                            <div class="blog-img-wrap" style="position:relative;overflow:hidden;height:<%= imgHeight %>;background:#f8f9fa;cursor:pointer;"
                                 onmouseenter="blogImgHover(this,true)" onmouseleave="blogImgHover(this,false)"
                                 onclick="openBlogSlideshow(JSON.parse(this.dataset.imgs), parseInt(this.dataset.idx))"
                                 data-imgs="<%= JSON.stringify(blog.images.map(i=>i.url)) %>" data-idx="0">
                                <img src="<%= blog.images[0].url %>" class="blog-slide-img" alt="<%= blog.title %>"
                                     style="width:100%;height:100%;object-fit:cover;transition:transform 0.4s ease;">
                                <!-- Overlay -->
                                <div class="blog-overlay" style="position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.55) 0%,rgba(0,0,0,0.1) 50%,transparent 100%);opacity:0;transition:opacity 0.3s ease;pointer-events:none;"></div>
                                <% if (blog.images.length > 1) { %>
                                    <span style="position:absolute;top:8px;right:8px;background:rgba(0,0,0,0.55);color:#fff;font-size:0.7rem;font-weight:700;border-radius:4px;padding:2px 7px;">
                                        <i class="fas fa-images me-1"></i><%= blog.images.length %>
                                    </span>
                                    <button class="blog-nav blog-nav-l" onclick="blogNav(event,this.parentElement,-1)"
                                        style="display:none;position:absolute;left:8px;top:50%;transform:translateY(-50%);background:rgba(0,0,0,0.45);border:none;color:#fff;font-size:1.6rem;border-radius:50%;width:38px;height:38px;cursor:pointer;z-index:2">&#8249;</button>
                                    <button class="blog-nav blog-nav-r" onclick="blogNav(event,this.parentElement,1)"
                                        style="display:none;position:absolute;right:8px;top:50%;transform:translateY(-50%);background:rgba(0,0,0,0.45);border:none;color:#fff;font-size:1.6rem;border-radius:50%;width:38px;height:38px;cursor:pointer;z-index:2">&#8250;</button>
                                    <div class="blog-ctr" style="display:none;position:absolute;bottom:6px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,0.45);color:#fff;font-size:0.75rem;border-radius:50px;padding:2px 10px;">1 / <%= blog.images.length %></div>
                                <% } %>
                            </div>
                        <% } %>
                        <div class="card-body">
                            <h5 class="card-title text-success"><%= blog.title %></h5>
                            <p class="card-text"><%= blog.description %></p>
                        </div>
                        <div class="card-footer text-muted d-flex justify-content-between align-items-center">
                            <small><i class="fas fa-calendar"></i> <%= new Date(blog.createdAt).toLocaleDateString(language === 'mr' ? 'mr-IN' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></small>
                            <small><i class="fas fa-user"></i> <%= blog.author %></small>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    <% } %>
</div>

<script>
function blogImgHover(wrap, show) {
    wrap.querySelectorAll('.blog-nav, .blog-ctr').forEach(el => el.style.display = show ? 'block' : 'none');
    const overlay = wrap.querySelector('.blog-overlay');
    if (overlay) overlay.style.opacity = show ? '1' : '0';
    const img = wrap.querySelector('.blog-slide-img');
    if (img) img.style.transform = show ? 'scale(1.05)' : 'scale(1)';
}
function blogNav(e, wrap, dir) {
    e.stopPropagation();
    const imgs = JSON.parse(wrap.dataset.imgs);
    let idx = (parseInt(wrap.dataset.idx) + dir + imgs.length) % imgs.length;
    wrap.dataset.idx = idx;
    wrap.querySelector('.blog-slide-img').src = imgs[idx];
    const ctr = wrap.querySelector('.blog-ctr');
    if (ctr) ctr.textContent = (idx+1) + ' / ' + imgs.length;
}
function openBlogSlideshow(urls, start) {
    window._ssU = urls; window._ssI = start;
    const render = () => { document.getElementById('bssImg').src = window._ssU[window._ssI]; document.getElementById('bssCtr').textContent = (window._ssI+1)+' / '+window._ssU.length; };
    window.bssNav = d => { window._ssI = (window._ssI+d+window._ssU.length)%window._ssU.length; render(); };
    render();
    new bootstrap.Modal(document.getElementById('blogSlideshowModal')).show();
}
</script>

<!-- Blog Slideshow Modal -->
<div class="modal fade" id="blogSlideshowModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" style="background:linear-gradient(135deg,#28a745,#20c997);border:none">
                <h5 class="modal-title text-white fw-bold"><i class="fas fa-images me-2"></i><%= t('View Images') %></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-2" style="position:relative;min-height:300px">
                <img id="bssImg" src="" class="img-fluid rounded" style="max-height:65vh">
                <button onclick="bssNav(-1)" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);background:rgba(40,167,69,0.15);border:1px solid rgba(40,167,69,0.3);color:var(--text-primary);font-size:1.8rem;border-radius:50%;width:42px;height:42px;cursor:pointer">&#8249;</button>
                <button onclick="bssNav(1)"  style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:rgba(40,167,69,0.15);border:1px solid rgba(40,167,69,0.3);color:var(--text-primary);font-size:1.8rem;border-radius:50%;width:42px;height:42px;cursor:pointer">&#8250;</button>
                <div id="bssCtr" style="color:var(--text-muted);font-size:0.85rem;margin-top:6px"></div>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
