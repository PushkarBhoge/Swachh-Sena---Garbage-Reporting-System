<%- include('../partials/header') %>
    <% const formatTextNumbers=(text)=> {
        if (typeof language !== 'undefined' && language === 'mr') {
        const devanagariMap = {'0':'०','1':'१','2':'२','3':'३','4':'४','5':'५','6':'६','7':'७','8':'८','9':'९'};
        return text.replace(/[0-9]/g, d => devanagariMap[d]);
        }
        return text;
        };
        %>
        <div class="container my-5">
            <div class="row justify-content-center">
                <div class="col-md-8">
                    <div class="card">
                        <div class="card-header text-center bg-success text-white">
                            <h3><i class="fas fa-heart"></i>
                                <%= t('Support Our Clean City Initiative') %>
                            </h3>
                        </div>
                        <div class="card-body">
                            <div class="text-center mb-4">
                                <p class="lead">
                                    <%= formatTextNumbers(t('Help us keep our city clean by supporting our garbage cleanup efforts')) %>
                                </p>
                                <p>
                                    <%= formatTextNumbers(t('Your donation helps fund cleanup operations, equipment, and team resources.')) %>
                                </p>
                            </div>

                            <form id="donationForm">
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label for="currency" class="form-label">
                                                <%= t('Currency') %>
                                            </label>
                                            <select class="form-select" id="currency" name="currency"
                                                onchange="updateCurrency()">
                                                <option value="INR" data-symbol="₹"><%= t('India - Rupee (₹)') %></option>
                                                <option value="USD" data-symbol="$"><%= t('America - Dollar ($)') %></option>
                                                <option value="EUR" data-symbol="€"><%= t('Europe - Euro (€)') %></option>
                                                <option value="CNY" data-symbol="¥"><%= t('China - Yuan (¥)') %></option>
                                                <option value="JPY" data-symbol="¥"><%= t('Japan - Yen (¥)') %></option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label for="amount" class="form-label">
                                                <%= t('Donation Amount') %>
                                            </label>
                                            <div class="input-group">
                                                <span class="input-group-text" id="currencySymbol">₹</span>
                                                <input type="number" class="form-control" id="amount" name="amount"
                                                    placeholder="<%= t('Enter amount') %>" min="1" required>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">
                                        <%= t('Quick Amount Selection') %>
                                    </label>
                                    <div class="row g-2">
                                        <div class="col-4 col-lg-2">
                                            <button type="button" class="btn btn-outline-success w-100 quick-amt-btn"
                                                onclick="setAmount(100)">
                                                <span id="quick1">₹100</span>
                                            </button>
                                        </div>
                                        <div class="col-4 col-lg-2">
                                            <button type="button" class="btn btn-outline-success w-100 quick-amt-btn"
                                                onclick="setAmount(500)">
                                                <span id="quick2">₹500</span>
                                            </button>
                                        </div>
                                        <div class="col-4 col-lg-2">
                                            <button type="button" class="btn btn-outline-success w-100 quick-amt-btn"
                                                onclick="setAmount(1000)">
                                                <span id="quick3">₹1000</span>
                                            </button>
                                        </div>
                                        <div class="col-4 col-lg-2">
                                            <button type="button" class="btn btn-outline-success w-100 quick-amt-btn"
                                                onclick="setAmount(2000)">
                                                <span id="quick4">₹2000</span>
                                            </button>
                                        </div>
                                        <div class="col-4 col-lg-2">
                                            <button type="button" class="btn btn-outline-success w-100 quick-amt-btn"
                                                onclick="setAmount(5000)">
                                                <span id="quick5">₹5000</span>
                                            </button>
                                        </div>
                                        <div class="col-4 col-lg-2">
                                            <button type="button" class="btn btn-outline-success w-100 quick-amt-btn"
                                                onclick="setAmount(10000)">
                                                <span id="quick6">₹10000</span>
                                            </button>
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label for="message" class="form-label">
                                        <%= t('Message') %> <span class="text-danger">*</span>
                                    </label>
                                    <textarea class="form-control" id="message" name="message" rows="3"
                                        placeholder="<%= t('Leave a message of support') %>" required></textarea>
                                </div>

                                <div class="text-center">
                                    <button type="submit" class="btn btn-success btn-lg" id="donateBtn">
                                        <i class="fas fa-heart"></i>
                                        <%= t('Donate Now') %>
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <script src="https://js.stripe.com/v3/"></script>
        <script>
            const language = '<%= typeof language !== "undefined" ? language : "en" %>';
            const devanagariMap = { '0': '०', '1': '१', '2': '२', '3': '३', '4': '४', '5': '५', '6': '६', '7': '७', '8': '८', '9': '९' };
            const formatNumber = (num) => {
                if (language === 'mr') {
                    return num.toString().replace(/[0-9]/g, d => devanagariMap[d]);
                }
                return num.toString();
            };

            const stripe = Stripe('<%= stripePublishableKey %>');
            const isLoggedIn = '<%= userId ? "yes" : "" %>' === 'yes';
            const exchangeRates = {};
            const baseCurrency = 'INR';

            // Currency symbols mapping
            const currencySymbols = {
                'INR': '₹',
                'USD': '$',
                'EUR': '€',
                'CNY': '¥',
                'JPY': '¥'
            };

            // Base amounts in INR for quick selection
            const baseAmounts = [100, 500, 1000, 2000, 5000, 10000];

            async function fetchExchangeRates() {
                try {
                    const response = await fetch(`https://api.exchangerate-api.com/v4/latest/${baseCurrency}`);
                    const data = await response.json();
                    Object.assign(exchangeRates, data.rates);
                    updateCurrency();
                } catch (error) {
                    console.error('Failed to fetch exchange rates:', error);
                }
            }

            let previousCurrency = 'INR';

            function updateCurrency() {
                const currencySelect = document.getElementById('currency');
                const selectedCurrency = currencySelect.value;
                const symbol = currencySymbols[selectedCurrency];
                const amountInput = document.getElementById('amount');

                document.getElementById('currencySymbol').textContent = symbol;

                // Convert existing amount to new currency
                if (amountInput.value && exchangeRates[selectedCurrency] && exchangeRates[previousCurrency]) {
                    const currentAmount = parseFloat(amountInput.value);
                    const inrAmount = previousCurrency === baseCurrency ? currentAmount : currentAmount / exchangeRates[previousCurrency];
                    const newAmount = selectedCurrency === baseCurrency ? inrAmount : inrAmount * exchangeRates[selectedCurrency];
                    amountInput.value = Math.round(newAmount);
                }

                baseAmounts.forEach((amount, index) => {
                    const convertedAmount = selectedCurrency === baseCurrency ?
                        amount :
                        Math.round(amount * (exchangeRates[selectedCurrency] || 1));

                    document.getElementById(`quick${index + 1}`).textContent = `${symbol}${formatNumber(convertedAmount)}`;
                });

                previousCurrency = selectedCurrency;
            }

            function setAmount(baseAmount) {
                const selectedCurrency = document.getElementById('currency').value;
                const convertedAmount = selectedCurrency === baseCurrency ?
                    baseAmount :
                    Math.round(baseAmount * (exchangeRates[selectedCurrency] || 1));

                document.getElementById('amount').value = convertedAmount;
            }

            document.getElementById('amount').addEventListener('input', () => { });

            document.getElementById('donationForm').addEventListener('submit', async function (e) {
                e.preventDefault();

                if (!isLoggedIn) { openAuthModal('login'); return; }

                const amount = document.getElementById('amount').value;
                const currency = document.getElementById('currency').value;
                const message = document.getElementById('message').value;

                if (!amount || amount <= 0) {
                    alert('Please enter a valid amount');
                    return;
                }

                if (!message) {
                    alert('Please fill in your message');
                    return;
                }

                const donateBtn = document.getElementById('donateBtn');
                donateBtn.disabled = true;
                donateBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';

                try {
                    const response = await fetch('/create-checkout-session', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ amount: parseFloat(amount), currency, message })
                    });

                    const data = await response.json();

                    if (!response.ok) {
                        throw new Error(data.error || 'Payment failed');
                    }

                    if (!data.sessionId) {
                        throw new Error('No session ID received');
                    }

                    const { error } = await stripe.redirectToCheckout({ sessionId: data.sessionId });

                    if (error) {
                        throw new Error(error.message);
                    }
                } catch (error) {
                    console.error('Payment error:', error);
                    alert(error.message || 'Payment failed. Please try again.');
                    donateBtn.disabled = false;
                    donateBtn.innerHTML = '<i class="fas fa-heart"></i> <%= t("Donate Now") %>';
                }
            });

            fetchExchangeRates();
            updateCurrency();

            if (window.location.search.includes('success=true')) {
                const urlParams = new URLSearchParams(window.location.search);
                const sessionId = urlParams.get('session_id');

                if (sessionId) {
                    fetch(`/verify-payment?session_id=${sessionId}`)
                        .then(res => res.json())
                        .then(data => {
                            if (data.success) {
                                alert('✓ Thank you for your donation!');
                            }
                            window.history.replaceState({}, document.title, window.location.pathname);
                        });
                } else {
                    alert('✓ Thank you for your donation!');
                    window.history.replaceState({}, document.title, window.location.pathname);
                }
            } else if (window.location.search.includes('canceled=true')) {
                alert('Payment was canceled');
                window.history.replaceState({}, document.title, window.location.pathname);
            }
        </script>

        <%- include('../partials/footer') %>