                    <p><%= formatTextNumbers(t('Conducted environmental workshops in 100+ schools, educating 50,000+ students about waste management and sustainability.')) %></p>
                    <span class="badge bg-info"><%= t('Completed') %></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Impact Stories -->
    <div class="row mb-5">
        <div class="col-md-12">
            <h2 class="text-center mb-4 text-success">💚 <%= t('Impact Stories') %></h2>
        </div>
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="text-success"><%= t('Riverside Park Transformation') %></h5>
                    <p class="text-muted"><small><i class="fas fa-calendar"></i> <%= new Date('2024-03-01').toLocaleDateString(language === 'mr' ? 'mr-IN' : 'en-US', { year: 'numeric', month: 'long' }) %></small></p>
                    <p><%= formatTextNumbers(t('Transformed a 5-acre dumping ground into a beautiful community park. Removed 50 tons of waste, planted 200 trees, and created recreational spaces for families.')) %></p>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="text-success"><%= t('Beach Cleanup Marathon') %></h5>
                    <p class="text-muted"><small><i class="fas fa-calendar"></i> <%= new Date('2024-01-01').toLocaleDateString(language === 'mr' ? 'mr-IN' : 'en-US', { year: 'numeric', month: 'long' }) %></small></p>
                    <p><%= formatTextNumbers(t('Organized a mega beach cleanup with 5,000 volunteers, collecting 15 tons of plastic waste and marine debris from 10 km of coastline.')) %></p>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="text-success"><%= t('Zero Waste Neighborhood') %></h5>
                    <p class="text-muted"><small><i class="fas fa-calendar"></i> <%= new Date('2023-12-01').toLocaleDateString(language === 'mr' ? 'mr-IN' : 'en-US', { year: 'numeric', month: 'long' }) %></small></p>
                    <p><%= formatTextNumbers(t('Successfully implemented zero-waste practices in Green Valley community, achieving 95% waste diversion through composting and recycling.')) %></p>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="text-success"><%= t('Corporate Partnership Initiative') %></h5>
                    <p class="text-muted"><small><i class="fas fa-calendar"></i> <%= new Date('2023-11-01').toLocaleDateString(language === 'mr' ? 'mr-IN' : 'en-US', { year: 'numeric', month: 'long' }) %></small></p>
                    <p><%= formatTextNumbers(t('Partnered with 20+ corporations for CSR-driven cleanup drives, engaging 3,000+ employees in environmental conservation activities.')) %></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Awards & Recognition -->
    <div class="row mb-5">
        <div class="col-md-12">
            <h2 class="text-center mb-4 text-success">🎖️ <%= t('Awards & Recognition') %></h2>
        </div>
        <div class="col-md-12">
            <div class="card">
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li class="mb-3"><i class="fas fa-trophy text-warning"></i> <strong><%= formatTextNumbers(t('Best Environmental NGO Award 2023')) %></strong> - <%= t('National Green Council') %></li>
                        <li class="mb-3"><i class="fas fa-trophy text-warning"></i> <strong><%= formatTextNumbers(t('Innovation in Waste Management 2023')) %></strong> - <%= t('Ministry of Environment') %></li>
                        <li class="mb-3"><i class="fas fa-trophy text-warning"></i> <strong><%= formatTextNumbers(t('Community Impact Award 2022')) %></strong> - <%= t('City Municipal Corporation') %></li>
                        <li class="mb-3"><i class="fas fa-trophy text-warning"></i> <strong><%= formatTextNumbers(t('Digital India Initiative Recognition 2022')) %></strong> - <%= t('Government of India') %></li>
                        <li class="mb-3"><i class="fas fa-trophy text-warning"></i> <strong><%= formatTextNumbers(t('Youth Engagement Excellence 2021')) %></strong> - <%= t('United Nations Environment Programme') %></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Call to Action -->
    <div class="row">
        <div class="col-md-12">
            <div class="card bg-success text-white text-center">
                <div class="card-body py-5">
                    <h2 class="mb-3"><%= t('Join Our Mission') %></h2>
                    <p class="lead mb-4"><%= t('Be part of the change. Together, we can create cleaner, greener communities.') %></p>
                    <a href="/report" class="btn btn-light btn-lg me-2 mb-2"><i class="fas fa-flag"></i> <%= t('Report Garbage') %></a>
                    <a href="/donate" class="btn btn-outline-light btn-lg mb-2"><i class="fas fa-heart"></i> <%= t('Support Us') %></a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function animateCounter(element) {
    const target = parseInt(element.getAttribute('data-target'));
    const duration = 1000;
    const increment = target / (duration / 16);
    let current = 0;
    
    const formatNumber = (num) => {
        const lang = '<%= language %>';
        if (lang === 'mr') {
            const devanagariMap = {'0':'०','1':'१','2':'२','3':'३','4':'४','5':'५','6':'६','7':'७','8':'८','9':'९'};
            return num.toString().replace(/[0-9]/g, d => devanagariMap[d]);
        }
        return num.toString();
    };
    
    const timer = setInterval(() => {
        current += increment;
        if (current >= target) {
            element.textContent = formatNumber(target.toLocaleString()) + '+';
            clearInterval(timer);
        } else {
            element.textContent = formatNumber(Math.floor(current).toLocaleString());
        }
    }, 16);
}

const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
        if (entry.isIntersecting) {
            animateCounter(entry.target);
            observer.unobserve(entry.target);
        }
    });
});

document.querySelectorAll('.counter').forEach(counter => {
    observer.observe(counter);
});
</script>

<%- include('../partials/footer') %>
