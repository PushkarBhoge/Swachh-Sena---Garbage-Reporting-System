<%- include('../partials/header') %>

<% 
const formatTextNumbers = (text) => {
    if (language === 'mr') {
        const devanagariMap = {'0':'०','1':'१','2':'२','3':'३','4':'४','5':'५','6':'६','7':'७','8':'८','9':'९'};
        return text.replace(/[0-9]+/g, match => match.split('').map(d => devanagariMap[d] || d).join(''));
    }
    return text;
};
%>

<div class="hero-section text-white py-5">
    <div class="container">
        <div class="d-flex align-items-center justify-content-center flex-wrap">
            <img src="<%= language === 'mr' ? '/assets/logo-mr.png' : '/assets/logo-eng.png' %>" alt="Swachh Sena Logo" class="hero-logo-xl me-4">
            <div class="text-start">
                <h1 class="display-3 fw-bold"><%= t('Our Work & Impact') %></h1>
                <p class="lead"><%= t('Making a difference, one cleanup at a time') %></p>
            </div>
        </div>
    </div>
</div>

<div class="container my-5">
    <!-- About NGO -->
    <div class="row mb-5">
        <div class="col-md-12">
            <div class="card">
                <div class="card-body text-center">
                    <h2 class="text-success mb-3">🌍 <%= t('Green Earth Foundation') %></h2>
                    <p class="lead"><%= t('A non-profit organization dedicated to creating cleaner, greener communities through innovative waste management and environmental awareness programs.') %></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Vision & Mission -->
    <div class="row mb-5">
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h3 class="text-success"><i class="fas fa-eye"></i> <%= t('Our Vision') %></h3>
                    <p><%= t('To create a sustainable future where every community lives in a clean, healthy environment free from waste pollution. We envision cities where waste management is efficient, citizens are environmentally conscious, and nature thrives alongside urban development.') %></p>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h3 class="text-success"><i class="fas fa-bullseye"></i> <%= t('Our Mission') %></h3>
                    <p><%= t('To empower communities through technology-driven waste management solutions, environmental education, and active citizen participation. We strive to reduce waste pollution, promote recycling, and create awareness about sustainable living practices.') %></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Achievements -->
    <div class="row mb-5">
        <div class="col-md-12">
            <h2 class="text-center mb-4 text-success">🏆 <%= t('Our Achievements') %></h2>
        </div>
        <div class="col-md-3 col-sm-6 mb-4">
            <div class="card text-center stat-card bg-primary text-white">
                <div class="card-body">
                    <h1 class="display-4 counter" data-target="2500">0</h1>
                    <p class="mb-0"><%= t('Garbage Spots Cleaned') %></p>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-4">
            <div class="card text-center stat-card bg-success text-white">
                <div class="card-body">
                    <h1 class="display-4 counter" data-target="50">0</h1>
                    <p class="mb-0"><%= t('Cleanup Teams') %></p>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-4">
            <div class="card text-center stat-card bg-warning text-white">
                <div class="card-body">
                    <h1 class="display-4 counter" data-target="15000">0</h1>
                    <p class="mb-0"><%= t('Volunteers Engaged') %></p>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6 mb-4">
            <div class="card text-center stat-card bg-info text-white">
                <div class="card-body">
                    <h1 class="display-4 counter" data-target="500">0</h1>
                    <p class="mb-0"><%= t('Waste Collected (Tons)') %></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Key Projects -->
    <div class="row mb-5">
        <div class="col-md-12">
            <h2 class="text-center mb-4 text-success">📋 <%= t('Key Projects') %></h2>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h4 class="text-success"><i class="fas fa-mobile-alt"></i> <%= t('Smart Reporting System') %></h4>
                    <p><%= t('Developed a citizen-friendly platform for reporting garbage spots with real-time tracking and automated team assignment.') %></p>
                    <span class="badge bg-success"><%= t('Active') %></span>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h4 class="text-success"><i class="fas fa-recycle"></i> <%= t('Community Recycling Drive') %></h4>
                    <p><%= formatTextNumbers(t('Organized monthly recycling drives in 25+ neighborhoods, promoting waste segregation and recycling awareness.')) %></p>
                    <span class="badge bg-success"><%= t('Ongoing') %></span>
