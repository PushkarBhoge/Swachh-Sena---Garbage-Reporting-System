<!-- ═══ AUTH MODAL ═══ -->
<div class="auth-modal-backdrop" id="authModalBackdrop"></div>

<div class="auth-modal" id="authModal" role="dialog" aria-modal="true">
    <button class="auth-modal-close" id="authModalClose" aria-label="Close">
        <i class="fas fa-times"></i>
    </button>

    <div class="auth-modal-inner">
        <!-- Left brand panel -->
        <div class="auth-modal-brand">
            <img src="/assets/logo-eng.png" alt="Swachh Sena">
            <h3>Swachh Sena</h3>
            <p>Keep Your City Clean</p>
            <i class="fas fa-recycle am-recycle"></i>
            <p class="am-tagline">Join us in making our community cleaner and greener</p>
            <div class="auth-modal-pills">
                <span>🏆 2500+ Spots Cleaned</span>
                <span>👥 50 Cleanup Teams</span>
            </div>
        </div>

        <!-- Right form panel -->
        <div class="auth-modal-form">
            <div id="authModalAlert" class="auth-modal-alert d-none"></div>

            <div class="mb-3">
                <h5 class="auth-modal-title">Welcome! 👋</h5>
                <p class="auth-modal-sub">Login or create an account to continue.</p>
            </div>

            <!-- Tabs -->
            <div class="auth-modal-tabs">
                <button class="auth-tab-btn active" data-tab="login">
                    <i class="fas fa-sign-in-alt me-1"></i> Login
                </button>
                <button class="auth-tab-btn" data-tab="signup">
                    <i class="fas fa-user-plus me-1"></i> Sign Up
                </button>
            </div>

            <!-- Login Form -->
            <form id="modalLoginForm" class="auth-tab-content active" data-tab="login">
                <div class="mb-3">
                    <label class="auth-label"><i class="fas fa-envelope me-1"></i> Email</label>
                    <input type="email" name="email" class="form-control auth-input" placeholder="Enter your email" required>
                </div>
                <div class="mb-4">
                    <label class="auth-label"><i class="fas fa-lock me-1"></i> Password</label>
                    <input type="password" name="password" class="form-control auth-input" placeholder="Enter your password" required>
                </div>
                <button type="submit" class="btn auth-submit-btn w-100">
                    <i class="fas fa-sign-in-alt me-2"></i> Login
                </button>
            </form>

            <!-- Signup Form -->
            <form id="modalSignupForm" class="auth-tab-content" data-tab="signup" style="display:none;">
                <div class="row g-2 mb-2">
                    <div class="col-6">
                        <label class="auth-label"><i class="fas fa-user me-1"></i> Name <span style="color:#dc3545">*</span></label>
                        <input type="text" name="name" class="form-control auth-input" placeholder="Your name" required>
                    </div>
                    <div class="col-6">
                        <label class="auth-label"><i class="fas fa-envelope me-1"></i> Email <span style="color:#dc3545">*</span></label>
                        <input type="email" name="email" class="form-control auth-input" placeholder="Your email" required>
                    </div>
                </div>
                <div class="mb-2">
                    <label class="auth-label"><i class="fas fa-lock me-1"></i> Password <span style="color:#dc3545">*</span></label>
                    <input type="password" name="password" class="form-control auth-input" placeholder="Minimum 6 characters" minlength="6" required>
                </div>
                <div class="row g-2 mb-2">
                    <div class="col-6">
                        <label class="auth-label"><i class="fas fa-phone me-1"></i> Phone <span style="color:#dc3545">*</span></label>
                        <input type="tel" name="phone" class="form-control auth-input" placeholder="10 digit number" maxlength="10" pattern="[0-9]{10}" required>
                    </div>
                    <div class="col-6">
                        <label class="auth-label"><i class="fas fa-city me-1"></i> City <span style="color:#dc3545">*</span></label>
                        <input type="text" name="city" class="form-control auth-input" placeholder="Your city" required>
                    </div>
                </div>
                <div class="mb-2">
                    <label class="auth-label"><i class="fas fa-map-marker-alt me-1"></i> Address <span style="color:#dc3545">*</span></label>
                    <input type="text" name="address" class="form-control auth-input" placeholder="Your address" required>
                </div>
                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <label class="auth-label"><i class="fas fa-map me-1"></i> State <span style="color:#dc3545">*</span></label>
                        <input type="text" name="state" class="form-control auth-input" placeholder="Your state" required>
                    </div>
                    <div class="col-6">
                        <label class="auth-label"><i class="fas fa-hashtag me-1"></i> Pincode <span style="color:#dc3545">*</span></label>
                        <input type="text" name="pincode" class="form-control auth-input" placeholder="6-digit pincode" maxlength="6" pattern="[0-9]{6}" required>
                    </div>
                </div>
                <button type="submit" class="btn auth-submit-btn w-100">
                    <i class="fas fa-user-plus me-2"></i> Create Account
                </button>
            </form>
        </div>
    </div>
</div>

<style>
/* Backdrop */
.auth-modal-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    z-index: 1050;
}
.auth-modal-backdrop.show { display: block; }

/* Modal shell */
.auth-modal {
    display: none;
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -48%) scale(0.95);
    z-index: 1060;
    width: 90%;
    max-width: 780px;
    border-radius: 24px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.18);
    box-shadow: 0 20px 60px rgba(0,0,0,0.35), 0 0 0 1px rgba(255,255,255,0.05) inset;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    background: rgba(255,255,255,0.04);
    transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1), opacity 0.25s ease;
    opacity: 0;
    animation: amFadeInUp 0.65s cubic-bezier(0.4,0,0.2,1) forwards;
}
.auth-modal.show {
    display: block;
    transform: translate(-50%, -50%) scale(1);
    opacity: 1;
}
@keyframes amFadeInUp {
    from { opacity: 0; transform: translate(-50%, -46%) scale(0.95); }
    to   { opacity: 1; transform: translate(-50%, -50%) scale(1); }
}

/* Close button */
.auth-modal-close {
    position: absolute;
    top: 14px;
    right: 16px;
    background: rgba(255,255,255,0.15);
    border: none;
    border-radius: 50%;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    color: white;
    font-size: 0.85rem;
    transition: background 0.2s;
}
.auth-modal-close:hover { background: rgba(0,0,0,0.25); }

.auth-modal-inner {
    display: flex;
    min-height: 440px;
}

/* ── Brand panel (matches .logo-section) ── */
.auth-modal-brand {
    width: 240px;
    flex-shrink: 0;
    background: linear-gradient(160deg, #28a745 0%, #1a6b35 50%, #20c997 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2.5rem 2rem;
    text-align: center;
    color: white;
    position: relative;
    overflow: hidden;
}
.auth-modal-brand::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 20%, rgba(255,255,255,0.12) 0%, transparent 60%);
}
.auth-modal-brand img {
    width: 90px;
    height: 90px;
    object-fit: contain;
    margin-bottom: 14px;
    filter: drop-shadow(0 6px 16px rgba(0,0,0,0.25));
    animation: amFloatLogo 3s ease-in-out infinite;
    position: relative;
}
@keyframes amFloatLogo {
    0%,100% { transform: translateY(0); }
    50%      { transform: translateY(-8px); }
}
.auth-modal-brand h3 {
    font-weight: 800;
    font-size: 1.5rem;
    margin: 0;
    letter-spacing: -0.5px;
    position: relative;
}
.auth-modal-brand > p {
    margin: 8px 0 0;
    opacity: 0.88;
    font-size: 0.88rem;
    position: relative;
}
.auth-modal-brand .am-recycle {
    color: rgba(255,255,255,0.6);
    font-size: 2.5rem;
    margin: 1rem 0 0.5rem;
    position: relative;
}
.auth-modal-brand .am-tagline {
    opacity: 0.75;
    font-size: 0.8rem;
    position: relative;
    padding: 0 0.5rem;
}
.auth-modal-pills {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 1rem;
    position: relative;
    width: 100%;
}
.auth-modal-pills span {
    background: rgba(255,255,255,0.18);
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: 50px;
    padding: 5px 14px;
    font-size: 0.76rem;
    font-weight: 600;
}

/* ── Form panel ── */
.auth-modal-form {
    flex: 1;
    padding: 2.5rem 2rem;
    overflow-y: auto;
    background: rgba(255,255,255,0.97);
}
.auth-modal-title {
    font-weight: 800;
    color: #1a2e1d;
    margin-bottom: 2px;
}
.auth-modal-sub {
    color: #4a6354;
    font-size: 0.875rem;
    margin: 0;
}

/* Alert */
.auth-modal-alert {
    border-radius: 11px;
    border: none;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 10px 14px;
    margin-bottom: 14px;
}
.auth-modal-alert.error   { background: #f8d7da; color: #842029; }
.auth-modal-alert.success { background: #d1e7dd; color: #0f5132; }

/* Tabs (matches .auth-tabs) */
.auth-modal-tabs {
    display: flex;
    gap: 0;
    background: #f0faf4;
    border-radius: 12px;
    padding: 4px;
    margin-bottom: 1.5rem;
    border: none;
    list-style: none;
}
.auth-tab-btn {
    flex: 1;
    border: none;
    background: transparent;
    border-radius: 9px;
    padding: 10px 28px;
    font-size: 0.9rem;
    font-weight: 600;
    color: #4a6354;
    cursor: pointer;
    transition: all 0.25s ease;
}
.auth-tab-btn.active {
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    color: white;
    box-shadow: 0 4px 14px rgba(40,167,69,0.3);
}

/* Labels */
.auth-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #4a6354;
    margin-bottom: 5px;
    display: block;
}

/* Inputs (matches .auth-form-control) */
.auth-input {
    border-radius: 11px !important;
    padding: 12px 15px !important;
    border: 1.5px solid #d4edda !important;
    font-size: 0.9rem !important;
    background: #f9fdfb !important;
    transition: all 0.25s ease !important;
}
.auth-input:focus {
    border-color: #28a745 !important;
    box-shadow: 0 0 0 3px rgba(40,167,69,0.18) !important;
    background: white !important;
    outline: none !important;
}

/* Submit button (matches .auth-btn) */
.auth-submit-btn {
    background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
    border: none;
    border-radius: 50px;
    padding: 12px;
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.3px;
    color: white;
    box-shadow: 0 4px 20px rgba(40,167,69,0.3);
    transition: all 0.3s ease;
}
.auth-submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(40,167,69,0.4);
    background: linear-gradient(135deg, #20a33c 0%, #17b587 100%);
    color: white;
}
.auth-submit-btn:active { transform: translateY(0); }

/* Dark mode */
[data-theme="dark"] .auth-modal-form {
    background: #152019;
}
[data-theme="dark"] .auth-modal-title { color: #e8f5ea; }
[data-theme="dark"] .auth-modal-sub   { color: #a8c9b0; }
[data-theme="dark"] .auth-modal-tabs  { background: #0f1f13; }
[data-theme="dark"] .auth-tab-btn     { color: #a8c9b0; }
[data-theme="dark"] .auth-label       { color: #a8c9b0; }
[data-theme="dark"] .auth-input {
    background: #152019 !important;
    border-color: #1e3a24 !important;
    color: #e8f5ea !important;
}
[data-theme="dark"] .auth-input:focus {
    background: #1a2e1d !important;
}

/* Mobile */
@media (max-width: 576px) {
    .auth-modal { width: 95%; max-height: 92vh; overflow-y: auto; }
    .auth-modal-inner { flex-direction: column; }
    .auth-modal-brand {
        width: 100%;
        padding: 1.5rem;
        flex-direction: row;
        gap: 14px;
        text-align: left;
        justify-content: flex-start;
    }
    .auth-modal-brand img { width: 48px; height: 48px; margin-bottom: 0; animation: none; }
    .auth-modal-brand h3  { font-size: 1rem; margin-bottom: 2px; }
    .auth-modal-brand > p, .auth-modal-brand .am-recycle,
    .auth-modal-brand .am-tagline, .auth-modal-pills { display: none; }
    .auth-modal-form { padding: 1.5rem; }
    .auth-tab-btn { padding: 8px 12px; font-size: 0.85rem; }
}
</style>

<script>
(function() {
    // Open / close helpers
    window.openAuthModal = function(tab) {
        document.getElementById('authModalBackdrop').classList.add('show');
        const modal = document.getElementById('authModal');
        modal.style.display = 'block';
        // Force reflow then add show for animation
        requestAnimationFrame(() => modal.classList.add('show'));
        document.body.style.overflow = 'hidden';
        if (tab) switchAuthTab(tab);
    };

    window.closeAuthModal = function() {
        const modal = document.getElementById('authModal');
        modal.classList.remove('show');
        document.getElementById('authModalBackdrop').classList.remove('show');
        document.body.style.overflow = '';
        setTimeout(() => { modal.style.display = 'none'; }, 300);
    };

    function switchAuthTab(tab) {
        document.querySelectorAll('.auth-tab-btn').forEach(b => b.classList.toggle('active', b.dataset.tab === tab));
        document.querySelectorAll('.auth-tab-content').forEach(f => {
            f.style.display = f.dataset.tab === tab ? 'block' : 'none';
        });
    }

    document.addEventListener('DOMContentLoaded', function() {
        // Tab switching
        document.querySelectorAll('.auth-tab-btn').forEach(btn => {
            btn.addEventListener('click', () => switchAuthTab(btn.dataset.tab));
        });

        // Close on backdrop / X
        document.getElementById('authModalClose').addEventListener('click', closeAuthModal);
        document.getElementById('authModalBackdrop').addEventListener('click', closeAuthModal);

        // Login form submit
        document.getElementById('modalLoginForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const fd = new FormData(this);
            const res = await fetch('/auth/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email: fd.get('email'), password: fd.get('password') })
            });
            const data = await res.json();
            if (data.success) {
                window.location.href = data.redirect || window.location.href;
            } else {
                showAuthAlert(data.error || 'Login failed', 'error');
            }
        });

        // Signup form submit
        document.getElementById('modalSignupForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const fd = new FormData(this);
            const res = await fetch('/auth/signup', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    name: fd.get('name'),
                    email: fd.get('email'),
                    password: fd.get('password'),
                    phone: fd.get('phone'),
                    address: fd.get('address'),
                    city: fd.get('city'),
                    state: fd.get('state'),
                    pincode: fd.get('pincode')
                })
            });
            const data = await res.json();
            if (data.success) {
                window.location.href = data.redirect || window.location.pathname;
            } else {
                showAuthAlert(data.error || 'Signup failed', 'error');
            }
        });
    });

    function showAuthAlert(msg, type) {
        const el = document.getElementById('authModalAlert');
        el.textContent = msg;
        el.className = 'auth-modal-alert ' + type;
    }
})();
</script>
