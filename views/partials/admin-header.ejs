<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Swachh Sena</title>
    <link rel="icon" href="/assets/logo-eng.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="admin-page">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/admin/dashboard">
                <img src="/assets/logo-eng.png" alt="Logo" height="50" class="me-2">
                Admin Panel
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link <%= title === 'Admin Dashboard' ? 'active' : '' %>" href="/admin/dashboard">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= title === 'Manage Reports' ? 'active' : '' %>" href="/admin/reports">Reports</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= title === 'Manage Teams' ? 'active' : '' %>" href="/admin/teams">Teams</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= title === 'Manage Blogs' ? 'active' : '' %>" href="/admin/blogs">Blogs</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= title === 'Newsletter Subscribers' ? 'active' : '' %>" href="/admin/subscribers">Subscribers</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= title === 'Donations' ? 'active' : '' %>" href="/admin/donations">Donations</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/auth/logout">Logout</a>
                    </li>
                    <li class="nav-item d-flex align-items-center">
                        <button id="themeToggle">
                            <i class="fas fa-moon" id="themeIcon"></i>
                        </button>
                    </li>
                </ul>
            </div>
        </div>
    </nav>