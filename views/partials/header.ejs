<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Swachh Sena - <%= title %></title>
    <link rel="icon" href="/assets/logo-eng.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/chatbot.css">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-success">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="<%= language === 'mr' ? '/assets/logo-mr.png' : '/assets/logo-eng.png' %>" alt="Logo" height="50" class="me-2">
                <%= t('Swachh Sena') %>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link <%= title === 'Garbage Reporting System' ? 'active' : '' %>" href="/"><%= t('Home') %></a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= title === 'Our Work' ? 'active' : '' %>" href="/our-work"><%= t('Our Work') %></a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= title === 'Report Garbage' ? 'active' : '' %>" href="/report"><%= t('Report Garbage') %></a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= title === 'View Reports' ? 'active' : '' %>" href="/reports"><%= t('View Reports') %></a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= title === 'Blogs' ? 'active' : '' %>" href="/blogs"><%= t('Blogs') %></a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= title === 'Create Blog' ? 'active' : '' %>" href="/create-blog"><%= t('Create Blog') %></a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= title === 'Donate' ? 'active' : '' %>" href="/donate"><%= t('Donate') %></a>
                    </li>
                    <li class="nav-item d-flex align-items-center ms-lg-2 mt-2 mt-lg-0">
                        <select class="form-select form-select-sm lang-selector" id="languageSelector">
                            <option value="en" <%= language === 'en' ? 'selected' : '' %>>English</option>
                            <option value="mr" <%= language === 'mr' ? 'selected' : '' %>>मराठी</option>
                        </select>
                    </li>
                    <li class="nav-item d-flex align-items-center ms-2">
                        <button type="button" class="btn btn-outline-light" id="themeToggle">
                            <i class="fas fa-moon" id="themeIcon"></i>
                        </button>
                    </li>
                    <% if (typeof userId !== 'undefined' && userId) { %>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                <span class="user-avatar"><%= (userName || 'U').charAt(0).toUpperCase() %></span>
                                <span class="d-none d-lg-inline"><%= userName || t('User') %></span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end user-dropdown">
                                <li class="user-dropdown-header">
                                    <div class="user-avatar-lg"><%= (userName || 'U').charAt(0).toUpperCase() %></div>
                                    <div class="user-dropdown-name"><%= userName || t('User') %></div>
                                </li>
                                <li><hr class="dropdown-divider my-1"></li>
                                <% if (userRole === 'user') { %>
                                    <li><a class="dropdown-item" href="/auth/profile"><i class="fas fa-user-edit me-2"></i><%= t('My Profile') %></a></li>
                                    <% if (typeof subscriberEmail !== 'undefined' && subscriberEmail) { %>
                                        <li><a class="dropdown-item" href="#" id="unsubscribeBtn"><i class="fas fa-bell-slash me-2"></i><%= t('Unsubscribe') %></a></li>
                                    <% } else { %>
                                        <li><a class="dropdown-item" href="#" id="subscribeBtn"><i class="fas fa-bell me-2"></i><%= t('Subscribe') %></a></li>
                                    <% } %>
                                    <li><hr class="dropdown-divider my-1"></li>
                                <% } %>
                                <li><a class="dropdown-item dropdown-item-danger" href="/auth/logout"><i class="fas fa-sign-out-alt me-2"></i><%= t('Logout') %></a></li>
                            </ul>
                        </li>
                    <% } else { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/auth/login"><%= t('Login') %></a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>