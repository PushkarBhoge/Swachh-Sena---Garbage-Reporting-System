<%- include('../partials/header') %>
<link rel="stylesheet" href="/css/auth.css">

<div class="container my-5">
    <div class="row">
        <!-- Left Column - Profile Info -->
        <div class="col-lg-6 mb-4">
            <div class="card profile-card">
                <div class="profile-header">
                    <i class="fas fa-user-circle"></i>
                    <h2><%= t('My Profile') %></h2>
                </div>
                <div class="card-body p-4">

                    <% if (success) { %>
                        <div class="alert alert-success alert-dismissible fade show auth-alert" role="alert">
                            <%= t('Profile updated successfully') %>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    <% } %>
                    <% if (error) { %>
                        <div class="alert alert-danger auth-alert"><%= error %></div>
                    <% } %>

                    <form action="/auth/profile" method="POST" id="profileForm">
                        <div class="mb-3">
                            <label class="form-label"><%= t('Name') %> <span style="color: red;">*</span></label>
                            <input type="text" name="name" class="form-control profile-form-control" value="<%= user.name %>" required disabled>
                        </div>

                        <div class="mb-3">
                            <label class="form-label"><%= t('Email') %> <span style="color: red;">*</span></label>
                            <input type="email" class="form-control profile-form-control" value="<%= user.email %>" disabled>
                        </div>

                        <div class="mb-3">
                            <label class="form-label"><%= t('Phone') %></label>
                            <input type="tel" name="phone" class="form-control profile-form-control" value="<%= user.phone || '' %>" pattern="[0-9]{10}" maxlength="10" placeholder="10 digit phone number" disabled>
                        </div>

                        <div class="mb-3">
                            <label class="form-label"><%= t('Address') %></label>
                            <input type="text" name="address" class="form-control profile-form-control" value="<%= user.address || '' %>" disabled>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label"><%= t('City') %></label>
                                <input type="text" name="city" class="form-control profile-form-control" value="<%= user.city || '' %>" disabled>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label"><%= t('State') %></label>
                                <input type="text" name="state" class="form-control profile-form-control" value="<%= user.state || '' %>" disabled>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label"><%= t('Pincode') %></label>
                            <input type="text" name="pincode" class="form-control profile-form-control" value="<%= user.pincode || '' %>" pattern="[0-9]{6}" maxlength="6" disabled>
                        </div>

                        <hr class="my-4">
                        <h5 class="mb-3"><%= t('Change Password') %></h5>

                        <div class="mb-3">
                            <label class="form-label"><%= t('Current Password') %></label>
                            <input type="password" name="currentPassword" class="form-control profile-form-control" disabled>
                        </div>

                        <div class="mb-3">
                            <label class="form-label"><%= t('New Password') %></label>
                            <input type="password" name="newPassword" class="form-control profile-form-control" minlength="6" placeholder="Minimum 6 characters" disabled>
                        </div>

                        <button type="button" class="btn btn-primary profile-btn-primary w-100 mt-3" id="editBtn" onclick="enableEdit()">
                            <i class="fas fa-edit"></i> <%= t('Edit Profile') %>
                        </button>
                        <button type="submit" class="btn btn-success profile-btn-success w-100 mt-3" id="saveBtn" style="display: none;">
                            <i class="fas fa-save"></i> <%= t('Update Profile') %>
                        </button>
                        <button type="button" class="btn btn-secondary profile-btn-secondary w-100 mt-2" id="cancelBtn" style="display: none;" onclick="cancelEdit()">
                            <i class="fas fa-times"></i> <%= t('Cancel') %>
                        </button>
                    </form>

                    <div class="text-center mt-3">
                        <a href="/" class="text-muted"><i class="fas fa-arrow-left"></i> <%= t('Back to Home') %></a>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Right Column - Donations -->
        <div class="col-lg-6 mb-4">
            <div class="card profile-card">
                <div class="profile-header">
                    <i class="fas fa-heart"></i>
                    <h2><%= t('My Donations') %></h2>
                </div>
                <div class="card-body p-4">
                    <div class="mb-4 p-4 text-center" style="background: linear-gradient(135deg, #28a745 0%, #20c997 100%); border-radius: 15px; color: white; box-shadow: 0 4px 15px rgba(40, 167, 69, 0.3);">
                        <h5 class="mb-2"><%= t('Total Donated') %></h5>
                        <h1 class="mb-2" style="font-weight: 700;" id="donationCounter">₹0.00</h1>
                        <small style="opacity: 0.9;"><%= t('All amounts converted to INR') %></small>
                    </div>
                    
                    <% if (donations.length === 0) { %>
                        <div class="alert alert-info text-center">
                            <p class="mb-2"><i class="fas fa-info-circle"></i> <%= t('No donations yet') %></p>
                            <a href="/donate" class="btn btn-success mt-2">
                                <i class="fas fa-heart"></i> <%= t('Make your first donation') %>
                            </a>
                        </div>
                    <% } else { %>
                        <h5 class="mb-3"><%= t('Donation History') %></h5>
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th><%= t('Date') %></th>
                                        <th><%= t('Amount') %></th>
                                        <th><%= t('Message') %></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% donations.forEach(donation => { 
                                        const formatDate = (date) => {
                                            return new Date(date).toLocaleDateString(language === 'mr' ? 'mr-IN' : 'en-US', { year: 'numeric', month: 'numeric', day: 'numeric' });
                                        };
                                        const formatNumber = (num) => {
                                            if (language === 'mr') {
                                                const marathiDigits = {'0':'०','1':'१','2':'२','3':'३','4':'४','5':'५','6':'६','7':'७','8':'८','9':'९'};
                                                return num.toString().replace(/[0-9]/g, d => marathiDigits[d]);
                                            }
                                            return num;
                                        };
                                    %>
                                        <tr>
                                            <td><%= formatDate(donation.createdAt) %></td>
                                            <td><span class="badge bg-success"><%= donation.currency %> <%= formatNumber(donation.amount.toFixed(2)) %></span></td>
                                            <td><%= donation.message %></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                        <div class="text-center mt-3">
                            <a href="/donate" class="btn btn-success">
                                <i class="fas fa-heart"></i> <%= t('Donate Again') %>
                            </a>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
const totalDonated = <%= totalDonated %>;
const language = '<%= language %>';
const counter = document.getElementById('donationCounter');
let current = 0;
const increment = totalDonated / 100;
const duration = 1500;
const stepTime = duration / 100;

function toMarathiNumber(num) {
    const marathiDigits = {'0':'०','1':'१','2':'२','3':'३','4':'४','5':'५','6':'६','7':'७','8':'८','9':'९'};
    return num.toString().replace(/[0-9]/g, d => marathiDigits[d]);
}

const timer = setInterval(() => {
    current += increment;
    if (current >= totalDonated) {
        current = totalDonated;
        clearInterval(timer);
    }
    const formatted = current.toFixed(2);
    counter.textContent = '₹' + (language === 'mr' ? toMarathiNumber(formatted) : formatted);
}, stepTime);

// Auto-hide success alert after 3 seconds
setTimeout(() => {
    const alert = document.querySelector('.alert-success');
    if (alert) {
        const bsAlert = new bootstrap.Alert(alert);
        bsAlert.close();
    }
}, 3000);

// Store original values
let originalValues = {};

function enableEdit() {
    const form = document.getElementById('profileForm');
    const inputs = form.querySelectorAll('input[type="text"], input[type="tel"], input[type="password"]');
    
    // Store original values
    inputs.forEach(input => {
        originalValues[input.name] = input.value;
        input.disabled = false;
    });
    
    document.getElementById('editBtn').style.display = 'none';
    document.getElementById('saveBtn').style.display = 'block';
    document.getElementById('cancelBtn').style.display = 'block';
}

function cancelEdit() {
    const form = document.getElementById('profileForm');
    const inputs = form.querySelectorAll('input[type="text"], input[type="tel"], input[type="password"]');
    
    // Restore original values
    inputs.forEach(input => {
        if (originalValues[input.name] !== undefined) {
            input.value = originalValues[input.name];
        }
        input.disabled = true;
    });
    
    document.getElementById('editBtn').style.display = 'block';
    document.getElementById('saveBtn').style.display = 'none';
    document.getElementById('cancelBtn').style.display = 'none';
}
</script>

<%- include('../partials/footer') %>
