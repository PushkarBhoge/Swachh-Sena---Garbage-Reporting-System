<%- include('../partials/admin-header') %>

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3 admin-filter-bar">
        <h2>Donations</h2>
        <div class="d-flex flex-wrap align-items-center gap-2">
            <input type="date" id="startDate" class="form-control" style="width: auto;">
            <span>to</span>
            <input type="date" id="endDate" class="form-control" style="width: auto;">
            <button class="btn btn-primary" onclick="downloadReport()">
                <i class="fas fa-download"></i> Download Report
            </button>
        </div>
    </div>

    <% if (success) { %>
        <div class="alert alert-success" data-auto-hide="true">✓ Deleted!</div>
    <% } %>

    <%
    const totalAmount = donations.filter(d => d.status === 'completed').reduce((sum, d) => {
        return sum + (d.amount * (rates[d.currency] || 1));
    }, 0);
    %>

    <div class="row mt-4 mb-4">
        <div class="col-6 col-md-4 mb-3">
            <div class="card text-white" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <div class="card-body">
                    <h5>Total Donations</h5>
                    <h2>₹<%= Math.round(totalAmount).toLocaleString() %></h2>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 mb-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5>Completed</h5>
                    <h2><%= donations.filter(d => d.status === 'completed').length %></h2>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 mb-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <h5>Pending</h5>
                    <h2><%= donations.filter(d => d.status === 'pending').length %></h2>
                </div>
            </div>
        </div>
    </div>

    <% if (donations.length === 0) { %>
        <div class="alert alert-info">No donations yet.</div>
    <% } else { %>
        <div class="table-responsive">
            <table class="table table-striped admin-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Donor Name</th>
                        <th>Message</th>
                        <th>Amount</th>
                        <th>Currency</th>
                        <th>Amount (INR)</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% donations.forEach(donation => {
                        const inrAmount = donation.amount * (rates[donation.currency] || 1);
                    %>
                        <tr>
                            <td data-label="Date"><%= new Date(donation.createdAt).toLocaleDateString() %></td>
                            <td data-label="Donor Name"><%= donation.donorName || 'Anonymous' %></td>
                            <td data-label="Message"><%= donation.message || '-' %></td>
                            <td data-label="Amount"><%= donation.amount.toLocaleString() %></td>
                            <td data-label="Currency"><%= donation.currency %></td>
                            <td data-label="Amount (INR)">₹<%= Math.round(inrAmount).toLocaleString() %></td>
                            <td data-label="Status">
                                <% if (donation.status === 'completed') { %>
                                    <span class="badge bg-success">Completed</span>
                                <% } else if (donation.status === 'pending') { %>
                                    <span class="badge bg-warning">Pending</span>
                                <% } else { %>
                                    <span class="badge bg-danger">Failed</span>
                                <% } %>
                            </td>
                            <td data-label="Actions">
                                <% if (donation.status === 'pending' || donation.status === 'failed') { %>
                                    <form action="/admin/donations/<%= donation._id %>?_method=DELETE" method="POST" style="display: inline;" onsubmit="return confirm('Delete this donation?');">
                                        <button type="submit" class="btn btn-danger btn-sm">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                <% } else { %>
                                    -
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>

<script>
function downloadReport() {
    const startDate = document.getElementById('startDate').value;
    const endDate = document.getElementById('endDate').value;

    if (!startDate || !endDate) {
        alert('Please select both start and end dates');
        return;
    }

    window.location.href = `/admin/donations/download?startDate=${startDate}&endDate=${endDate}`;
}
</script>

<%- include('../partials/footer') %>
