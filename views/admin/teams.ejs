<%- include('../partials/admin-header') %>

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Manage Teams</h2>
        <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addTeamModal">Add Team</button>
    </div>
    
    <% if (success) { %>
        <div class="alert alert-success" data-auto-hide="true">✓ Done!</div>
    <% } %>
    
    <% if (teams.length === 0) { %>
        <div class="alert alert-info">No teams. Create one!</div>
    <% } else { %>
        <div class="row">
            <% teams.forEach(team => { %>
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0"><%= team.name %></h5>
                            <div class="dropdown">
                                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
                                    Actions
                                </button>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#editTeamModal<%= team._id %>">Edit</a></li>
                                    <li><a class="dropdown-item text-danger" href="#" onclick="deleteTeam('<%= team._id %>')">Delete</a></li>
                                </ul>
                            </div>
                        </div>
                        <div class="card-body">
                            <h6>Workers (<%= team.workers.length %>):</h6>
                            <% if (team.workers.length === 0) { %>
                                <p class="text-muted">No workers assigned</p>
                            <% } else { %>
                                <ul class="list-group list-group-flush">
                                    <% team.workers.forEach(worker => { %>
                                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                            <%= worker.name %>
                                            <button class="btn btn-sm btn-outline-danger" onclick="removeWorker('<%= team._id %>', '<%= worker._id %>')">
                                                Remove
                                            </button>
                                        </li>
                                    <% }) %>
                                </ul>
                            <% } %>
                            <button class="btn btn-sm btn-primary mt-2" data-bs-toggle="modal" data-bs-target="#addWorkerModal<%= team._id %>">
                                Add Worker
                            </button>
                        </div>
                    </div>
                </div>
                
                <!-- Edit Team Modal -->
                <div class="modal fade" id="editTeamModal<%= team._id %>" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <form action="/admin/teams/<%= team._id %>?_method=PUT" method="POST">
                                <div class="modal-header">
                                    <h5 class="modal-title">Edit Team</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="mb-3">
                                        <label class="form-label">Team Name</label>
                                        <input type="text" name="name" class="form-control" value="<%= team.name %>" required>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                    <button type="submit" class="btn btn-primary">Update</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                
                <!-- Add Worker Modal -->
                <div class="modal fade" id="addWorkerModal<%= team._id %>" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <form action="/admin/teams/<%= team._id %>/workers" method="POST">
                                <div class="modal-header">
                                    <h5 class="modal-title">Add Worker to <%= team.name %></h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="mb-3">
                                        <label class="form-label">Worker Name</label>
                                        <input type="text" name="workerName" class="form-control" required>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                    <button type="submit" class="btn btn-primary">Add Worker</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>

<!-- Add Team Modal -->
<div class="modal fade" id="addTeamModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="/admin/teams" method="POST">
                <div class="modal-header">
                    <h5 class="modal-title">Add New Team</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Team Name</label>
                        <input type="text" name="name" class="form-control" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Add Team</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
let deleteInProgress = false;

function deleteTeam(teamId) {
    if (deleteInProgress) return;
    if (confirm('Are you sure you want to delete this team?')) {
        deleteInProgress = true;
        fetch(`/admin/teams/${teamId}`, {
            method: 'DELETE'
        }).then(() => {
            location.reload();
        });
    }
}

function removeWorker(teamId, workerId) {
    if (deleteInProgress) return;
    if (confirm('Are you sure you want to remove this worker?')) {
        deleteInProgress = true;
        fetch(`/admin/teams/${teamId}/workers/${workerId}`, {
            method: 'DELETE'
        }).then(() => {
            location.reload();
        });
    }
}
</script>

<%- include('../partials/footer') %>