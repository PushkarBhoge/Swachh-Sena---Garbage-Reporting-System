<%- include('../partials/admin-header') %>

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3 admin-filter-bar">
        <h2>Registered Users</h2>
    </div>

    <% if (success) { %>
        <div class="alert alert-success" data-auto-hide="true">✓ User deleted successfully!</div>
    <% } %>

    <div class="row mt-4 mb-4">
        <div class="col-6 col-md-4 mb-3">
            <div class="card text-white" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                <div class="card-body">
                    <h5>Total Users</h5>
                    <h2><%= users.length %></h2>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 mb-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5>Subscribed</h5>
                    <h2><%= users.filter(u => u.isSubscribed).length %></h2>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 mb-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <h5>Not Subscribed</h5>
                    <h2><%= users.filter(u => !u.isSubscribed).length %></h2>
                </div>
            </div>
        </div>
    </div>

    <% if (users.length === 0) { %>
        <div class="alert alert-info">No users registered yet.</div>
    <% } else { %>
        <table class="table table-striped admin-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th class="d-none d-md-table-cell">Phone</th>
                    <th class="d-none d-md-table-cell">City</th>
                    <th>Subscription</th>
                    <th class="d-none d-md-table-cell">Registered At</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(user => { %>
                    <tr class="subscriber-row" style="cursor: pointer;"
                        data-name="<%= user.name %>"
                        data-email="<%= user.email %>"
                        data-phone="<%= user.phone || 'N/A' %>"
                        data-city="<%= user.city || 'N/A' %>"
                        data-subscribed="<%= user.isSubscribed %>"
                        data-date="<%= new Date(user.createdAt).toLocaleDateString() %>">
                        <td data-label="Name"><%= user.name %></td>
                        <td data-label="Email"><%= user.email %></td>
                        <td data-label="Phone" class="d-none d-md-table-cell"><%= user.phone || 'N/A' %></td>
                        <td data-label="City" class="d-none d-md-table-cell"><%= user.city || 'N/A' %></td>
                        <td data-label="Subscription">
                            <% if (user.isSubscribed) { %>
                                <span class="badge bg-success"><i class="fas fa-check-circle"></i> Subscribed</span>
                            <% } else { %>
                                <span class="badge bg-secondary"><i class="fas fa-times-circle"></i> Not Subscribed</span>
                            <% } %>
                        </td>
                        <td data-label="Registered At" class="d-none d-md-table-cell"><%= new Date(user.createdAt).toLocaleDateString() %></td>
                        <td data-label="Actions" onclick="event.stopPropagation()">
                            <form action="/admin/subscribers/<%= user._id %>?_method=DELETE" method="POST" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this user?');">
                                <button type="submit" class="btn btn-danger btn-sm d-inline-flex align-items-center gap-1">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    <% } %>
</div>

<!-- User Detail Modal -->
<div class="modal fade" id="userDetailModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">User Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <table class="table table-borderless mb-0">
                    <tbody>
                        <tr><th style="width:40%">Name</th><td id="modal-name"></td></tr>
                        <tr><th>Email</th><td id="modal-email"></td></tr>
                        <tr><th>Phone</th><td id="modal-phone"></td></tr>
                        <tr><th>City</th><td id="modal-city"></td></tr>
                        <tr><th>Subscription</th><td id="modal-subscribed"></td></tr>
                        <tr><th>Registered At</th><td id="modal-date"></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
setTimeout(() => {
    const alert = document.querySelector('[data-auto-hide]');
    if (alert) new bootstrap.Alert(alert).close();
}, 3000);

document.querySelectorAll('.subscriber-row').forEach(row => {
    row.addEventListener('click', () => {
        document.getElementById('modal-name').textContent = row.dataset.name;
        document.getElementById('modal-email').textContent = row.dataset.email;
        document.getElementById('modal-phone').textContent = row.dataset.phone;
        document.getElementById('modal-city').textContent = row.dataset.city;
        document.getElementById('modal-subscribed').innerHTML = row.dataset.subscribed === 'true'
            ? '<span class="badge bg-success"><i class="fas fa-check-circle"></i> Subscribed</span>'
            : '<span class="badge bg-secondary"><i class="fas fa-times-circle"></i> Not Subscribed</span>';
        document.getElementById('modal-date').textContent = row.dataset.date;
        new bootstrap.Modal(document.getElementById('userDetailModal')).show();
    });
});
</script>

<%- include('../partials/footer') %>
